<script>
// ── Scroll reveal ──────────────────────────────────────────
const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry, i) => {
    if (entry.isIntersecting) {
      setTimeout(() => entry.target.classList.add('vis'), i * 60);
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ── Edit mode ──────────────────────────────────────────────
// Selectors for all editable text — skips structural/nav/icon elements
const EDITABLE_SELECTORS = [
  'h1','h2','h3','h4',
  'p','blockquote',
  '.hero-eyebrow','.hero-sub-text','.hero-location',
  '.pull-quote','.pull-quote-es',
  '.label','.section-label',
  '.rev-night','.rev-day','.rev-name','.rev-fee','.rev-annual',
  '.free-kicker','.free-title','.free-body','.free-body-es',
  '.fi-title','.fi-body',
  '.fund-tag','.fund-title','.fund-body',
  '.fs-num','.fs-label','.fs-sub',
  '.how-title','.how-intro',
  '.tc-role','.tc-name','.tc-desc','.tc-gift',
  '.pi-name','.pi-desc',
  '.phase-num','.phase-tag',
  '.phases-title','.phases-sub',
  '.closing-en','.closing-es','.closing-meta',
  '.footer-logo','.footer-address',
  '.stat-grid .pull-quote',
  '.team-intro-text','.team-title',
  '.ticker-item',
];

let editMode = false; // starts locked

function setEditMode(on) {
  editMode = on;
  document.querySelectorAll('[data-editable]').forEach(el => {
    el.contentEditable = on ? 'true' : 'false';
  });
  const bar   = document.getElementById('edit-bar');
  const btn   = document.getElementById('edit-btn');
  const hint  = document.getElementById('edit-hint');
  bar.style.background = on ? '#1a1a1a' : '#0f2a18';
  btn.textContent = on ? 'LOCK ✓' : 'EDIT TEXT';
  hint.textContent = on
    ? 'Click any text to edit — all changes stay in your browser'
    : 'Locked for presenting — click EDIT TEXT to make changes';
}

function toggleEdit() {
  setEditMode(!editMode);
}

// Tag all editable nodes
function initEditable() {
  const seen = new Set();
  EDITABLE_SELECTORS.forEach(sel => {
    document.querySelectorAll(sel).forEach(el => {
      // Skip nav links, the edit bar itself, ticker (cosmetic only)
      if (el.closest('#edit-bar') || el.closest('nav ul') || el.closest('.ticker-wrap')) return;
      if (seen.has(el)) return;
      seen.add(el);
      el.dataset.editable = '1';
      el.contentEditable = 'false';
      // Prevent Enter from inserting <div> blocks
      el.addEventListener('keydown', e => {
        if (e.key === 'Enter') { e.preventDefault(); document.execCommand('insertLineBreak'); }
      });
    });
  });
}

// Cmd/Ctrl+S hint
document.addEventListener('keydown', e => {
  if ((e.metaKey || e.ctrlKey) && e.key === 's') {
    e.preventDefault();
    const hint = document.getElementById('edit-hint');
    const prev = hint.textContent;
    hint.textContent = '✓ To save permanently: File → Save Page As... (Webpage, Complete)';
    hint.style.color = '#5dba7a';
    setTimeout(() => { hint.textContent = prev; hint.style.color = ''; }, 3500);
  }
});

initEditable();
</script>

